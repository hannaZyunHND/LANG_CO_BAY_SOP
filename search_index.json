ư":{"docs":{},"u":{"docs":{"./":{"ref":"./","tf":0.0035587188612099642}}}}},"length":195},"corpusTokens":["&","(checklist)","(e&s):","(f&b):","(front","(housekeeping):","(hr):","(kitchen):","(kèm","(risk","(sop)","20","30","6","bao","bar","biên","buffet,","buồng","bán","bên","bước","bạn","bản","bảo","bếp","bị,","bộ","ca","cao","cart","check","chi","chia","chiến","cho","chuẩn","chuẩn.","chào","chéo.","chạm","chỉnh","cung","các","cách","cô","cô.","công","cấp","cấp,","cấp.","cấu","cố","cốt","cộng","cụ","của","cứu","diện","down","duy","dẫn","dịch","dụng","dụng,","dựa","giới","gồm:","hiện","hiệu","hoàn","hoạt","huế","hàng","hành","hình","hóa","hướng","hệ","học.","hợp","in/check","kho","khoa","khu","khách","khẩn","khối","kế","kết","kịch","kỹ","la","linh","liệu","làm","lòng","lõi:","lý","lăng","lương","management).","menu","mô","mạo","mỗi","mục","mừng","nghiệm","nghiệp","ngừa","nhà","nhân","nhập/xuất","ninh","ninh,","nài","nướng","nấu","office):","out","phòng","phòng,","phòng.","phẩm,","phục","quy","quả","quản","quỹ","ro","room","rủi","service.","sinh","sơ","sạch","sạn","sảnh","sử","sự","thiết","thiệu","thoại),","thuật","thành","thống","thức","thực","tinh","tiên,","tiêu","tiết","tiền","toàn","toán","tra","trái","trên","trì","trình","trình.","trúc","trải","turn","tuyển","tuần","tài","tán","tính","tối","từng","việc","vui","và","vận","vệ","với","vụ","vực","xếp","xử","áp","điều","đích,","đúng","được","đảm","đầu","đẳng","đến","đều","để","định","ưu"],"pipeline":["stopWordFilter","stemmer"]},"store":{"./":{"url":"./","title":"Giới thiệu","keywords":"","body":"HỆ THỐNG QUY TRÌNH VẬN HÀNH TIÊU CHUẨN (SOP)\nKhách sạn Lăng Cô - Huế\nChào mừng bạn đến với Hệ thống Quy trình Vận hành Tiêu chuẩn (SOP) của Khách sạn Lăng Cô. Bộ tài liệu này được thiết kế và tinh chỉnh dựa trên tiêu chuẩn quản lý khách sạn cao cấp, kết hợp tính thực chiến và linh hoạt để áp dụng hiệu quả cho mô hình khách sạn quy mô 20-30 phòng.\nCấu trúc Hệ thống\nHệ thống được chia làm 6 khối cốt lõi:\n\nKhối Tiền sảnh (Front Office): Đảm bảo trải nghiệm chạm đầu tiên, xử lý check-in/check-out và các nghiệp vụ bán hàng chéo.\nKhối Buồng phòng (Housekeeping): Tiêu chuẩn làm sạch phòng, duy trì diện mạo khu vực công cộng và cung cấp dịch vụ Turn-down đẳng cấp.\nKhối Nhà hàng & Bar (F&B): Chuẩn hóa cách thức phục vụ Buffet, A-la-carte và Room Service.\nKhối Bếp (Kitchen): Quy trình vệ sinh an toàn thực phẩm, quản lý nhập/xuất kho và nấu nướng đúng công thức chuẩn.\nKhối Kỹ thuật & An ninh (E&S): Tuần tra an ninh, bảo trì phòng ngừa sự cố và các kịch bản sơ tán khẩn cấp.\nKhối Nhân sự (HR): Tiêu chuẩn tuyển dụng, tính toán định biên tối ưu quỹ lương và xếp ca làm việc khoa học.\n\nMỗi quy trình đều được thiết kế bao gồm: Mục đích, Công cụ chuẩn bị, Các bước thực hiện chi tiết (kèm Kịch bản thoại), Tiêu chuẩn hoàn thành (Checklist) và Hướng dẫn xử lý rủi ro (Risk Management).\n\nVui lòng sử dụng menu bên trái để điều hướng và tra cứu chi tiết từng quy trình.\n"}}}